2001000A    // addi $1, $0, 10      -> $1 = 10
20020014    // addi $2, $0, 20      -> $2 = 20
08000006    // j instruction 6      -> Jump to address 24

2003001E    // addi $3, $0, 30      -> SHOULD BE FLUSHED ($3 stays 0)
20040028    // addi $4, $0, 40      -> SHOULD BE FLUSHED ($4 stays 0)
20050032    // addi $5, $0, 50      -> SHOULD BE FLUSHED ($5 stays 0)

2006003C    // addi $6, $0, 60      -> Executed ($6 = 60)



