00088080    // sll  $16, $8, 2        -> $16 = 40
00098842    // srl  $17, $9, 1        -> $17 = 10
00089043    // sra  $18, $8, 1        -> $18 = 5
02089804    // sllv $19, $8, $16      -> $19 = 2560
0209A006    // srlv $20, $9, $16      -> $20 = 0
0208A807    // srav $21, $8, $16      -> $21 = 0
